# Ratesight — OPTIONAL secret overrides
#
# The plugin ships with working defaults for these, so you normally do NOT
# need to set anything. Define them in wp-config.php only if you want to
# override the bundled values (e.g. after rotating the secrets):
#
#   define( 'RATESIGHT_STATE_SECRET', 'your-state-secret-here' );
#   define( 'RATESIGHT_TOKEN_SECRET', 'your-token-secret-here' );
#
# These are a shared (symmetric) secret: any value you set here MUST match the
# STATE_SECRET / TOKEN_SECRET you set on the Cloudflare Worker (oauth.ratesight.com).

RATESIGHT_STATE_SECRET=
RATESIGHT_TOKEN_SECRET=
