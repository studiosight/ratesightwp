# Ratesight — secret configuration template
#
# These two values are sensitive and must match the secrets you set on your
# Cloudflare Worker (oauth.ratesight.com). They are NOT stored in the plugin
# source. Add them to your site's wp-config.php (above the
# "/* That's all, stop editing! */" line):
#
#   define( 'RATESIGHT_STATE_SECRET', 'your-state-secret-here' );
#   define( 'RATESIGHT_TOKEN_SECRET', 'your-token-secret-here' );
#
# Generate fresh random values (e.g. `openssl rand -hex 20`) and set the same
# values as STATE_SECRET / TOKEN_SECRET in the Worker.

RATESIGHT_STATE_SECRET=
RATESIGHT_TOKEN_SECRET=
