# Ratesight — REQUIRED secrets
#
# The plugin ships with NO bundled defaults for these. You MUST define them in
# wp-config.php for the OAuth features (GSC / GBP) to work:
#
#   define( 'RATESIGHT_STATE_SECRET', 'your-state-secret-here' );
#   define( 'RATESIGHT_TOKEN_SECRET', 'your-token-secret-here' );
#
# These are a shared (symmetric) secret: the values you set MUST match the
# STATE_SECRET / TOKEN_SECRET you set on the Cloudflare Worker (oauth.ratesight.com).
# Generate strong random values, e.g.  openssl rand -hex 20
# Until both are defined, the OAuth features stay disabled.

RATESIGHT_STATE_SECRET=
RATESIGHT_TOKEN_SECRET=
